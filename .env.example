# ───────────────────────────────────────────
# REQUIRED — Slack OAuth (multi-tenant)
# ───────────────────────────────────────────

# From your Slack App → Basic Information → App Credentials
SLACK_CLIENT_ID=1234567890.1234567890
SLACK_CLIENT_SECRET=abcd1234...
SLACK_SIGNING_SECRET=64a7672946aca3510938f741afee6b8a

# Any random long string — used to sign the OAuth `state` param to prevent CSRF.
# Generate with:  openssl rand -hex 32
SLACK_STATE_SECRET=replace-me-with-a-long-random-string

# ───────────────────────────────────────────
# REQUIRED — OpenAI + Database
# ───────────────────────────────────────────

OPENAI_API_KEY=sk-...
DATABASE_URL=postgresql://user:password@your-host.neon.tech/dbname?sslmode=require

# ───────────────────────────────────────────
# REQUIRED — Public base URL
# ───────────────────────────────────────────

# The public HTTPS URL of THIS server (no trailing slash). For local dev with ngrok:
#   BASE_URL=https://abcd-1234.ngrok-free.app
# For production:
#   BASE_URL=https://aiptima.yourdomain.com
# The landing page renders the install button using BASE_URL/slack/install.
BASE_URL=

PORT=3030

# ───────────────────────────────────────────
# OWNER LANGUAGE & LOCALE
# ───────────────────────────────────────────

# Default language for Home Tab, task cards. Supported: en | zh
OWNER_LANGUAGE=en

# Timezone shown to the AI for natural-language time parsing context.
DEFAULT_TIMEZONE=America/New_York

# Org name used in the system prompt.
ORGANIZATION_NAME=Aiptima

# ───────────────────────────────────────────
# AI MODELS
# ───────────────────────────────────────────

OPENAI_MODEL=gpt-4.1
OPENAI_SUMMARY_MODEL=gpt-4.1-mini
OPENAI_TEMPERATURE=0.2

# ───────────────────────────────────────────
# CADENCE & SCHEDULERS
# ───────────────────────────────────────────

PROGRESS_NUDGE_HOUR=10
PROGRESS_NUDGE_URGENT_SECOND_HOUR=15
PROGRESS_NUDGE_CRON=*/10 * * * *
# Silence-surfacing scheduler (replaces the old auto-BLOCKED behavior).
# It does NOT change task status — it just surfaces facts (silence duration, deadline,
# last known state) to the owner so the owner can decide whether to nudge or step in.
PROGRESS_SILENCE_CRON=*/5 * * * *
REMINDER_CRON=* * * * *
MIN_NUDGE_INTERVAL_MS=14400000

# ───────────────────────────────────────────
# SILENCE SENSITIVITY (per task priority — see product brief red line #5)
# ───────────────────────────────────────────
# How long an employee can stay silent after a check-in before Aiptima surfaces the
# silence (as a fact, no judgment) to the owner. Higher priority = shorter tolerance.
# Once surfaced, SILENCE_RE_ALERT_COOLDOWN_MS prevents repeat alerts on the same window.
SILENCE_THRESHOLD_URGENT_MS=3600000      # 1h
SILENCE_THRESHOLD_HIGH_MS=10800000       # 3h
SILENCE_THRESHOLD_NORMAL_MS=28800000     # 8h
SILENCE_THRESHOLD_LOW_MS=86400000        # 24h
SILENCE_RE_ALERT_COOLDOWN_MS=21600000    # 6h

# ───────────────────────────────────────────
# RUNTIME
# ───────────────────────────────────────────

CONVERSATION_HISTORY_LIMIT=40
LOG_LEVEL=info
# BOLT_LOG_LEVEL=warn   # debug | info | warn | error (defaults to warn)
