generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

/// Lifecycle of a task. PENDING_CLARIFICATION = AI is still gathering info from the owner.
enum TaskStatus {
  PENDING_CLARIFICATION
  NOT_STARTED
  IN_PROGRESS
  BLOCKED
  COMPLETED
  FAILED
  CANCELLED
}

enum TaskPriority {
  LOW
  NORMAL
  HIGH
  URGENT
}

model Task {
  id                     String       @id @default(cuid())
  title                  String
  description            String?
  time                   DateTime
  assignee               String
  assignees              String[]

  /// The Slack workspace (team) this task belongs to. Required for multi-tenant routing.
  teamId                 String?
  enterpriseId           String?

  channelId              String
  channelMessageTs       String?
  threadTs               String?
  createdBy              String
  initiator              String?
  status                 TaskStatus   @default(NOT_STARTED)
  priority               TaskPriority @default(NORMAL)

  progressPercent        Int          @default(0)
  lastProgressSummary    String?
  lastProgressAt         DateTime?
  lastNudgeAt            DateTime?

  // Legacy / runtime flags
  completed              Boolean      @default(false)
  completedAt            DateTime?
  notCompletedReason     String?
  notCompletedReasonAt   DateTime?
  deadlineReminderSentAt DateTime?
  progressPingSentAt     DateTime?
  progressAutoFailedAt   DateTime?

  /// Last time we surfaced silence (no employee reply) to the owner. Prevents repeat alerts
  /// for the same silence window. Does NOT change task status — silence is a fact for the
  /// owner to act on, not a judgment AI makes (see product brief §2.5 / red line #1).
  lastSilenceAlertAt     DateTime?

  createdAt              DateTime     @default(now())
  updatedAt              DateTime     @updatedAt

  progressUpdates        ProgressUpdate[]

  @@index([assignee])
  @@index([initiator])
  @@index([status])
  @@index([time])
  @@index([teamId])
}

/// One row per progress signal: employee replies, AI summaries, auto-marks, etc.
model ProgressUpdate {
  id              String      @id @default(cuid())
  taskId          String
  task            Task        @relation(fields: [taskId], references: [id], onDelete: Cascade)

  /// "employee_reply" | "ai_summary" | "auto_timeout" | "manual_owner" | "system"
  source          String

  /// Slack user id who triggered this update (employee or owner). Null for system events.
  authorId        String?

  /// Original raw text (what the employee said).
  rawText         String?

  /// AI-generated owner-facing summary (succinct, language-aware).
  summary         String?

  /// Snapshot of the progress percent at the moment of this update.
  progressPercent Int?

  /// Snapshot of the task status at the moment of this update.
  statusAtTime    TaskStatus?

  createdAt       DateTime    @default(now())

  @@index([taskId, createdAt])
}

/// Organizational memory: what the owner means by each nickname/role in *this* workspace.
///
/// This is the moat. Anyone can build a Slack bot that parses intent; only running in one
/// company for months produces "the owner's '小王' means U03XYZ" — and changing tools means
/// retraining all of that. See product brief §1.4 and §4.
///
/// Sources (`source`):
///   - "owner_confirmed"   — owner explicitly confirmed (highest trust)
///   - "owner_inferred"    — derived from how the owner referred to a Slack mention in conversation
///   - "slack_profile"     — derived from Slack profile fields (display_name, real_name, title)
///   - "channel_membership"— derived from being in #design etc.
///
/// We never block the owner to "enroll" people — these rows accumulate passively from
/// natural conversation (red line #3).
model PersonAlias {
  id              String   @id @default(cuid())

  teamId          String?
  enterpriseId    String?

  /// The string the owner used: "小王", "Lisa", "design", "the marketing guy".
  /// Stored case-normalized (lower). Matched against incoming references.
  alias           String

  /// The Slack user ID this alias resolves to.
  slackUserId     String

  /// What kind of reference this alias represents — useful for future role-based routing
  /// ("the owner said 'design', and we know Lisa + Tom are on design").
  ///   - "person"   — alias points at one specific human
  ///   - "role"     — alias represents a role/team (may have multiple slackUserIds via separate rows)
  kind            String   @default("person")

  /// How we learned this mapping. See enum-doc above.
  source          String

  /// 0–100. owner_confirmed=100, slack_profile=70, channel_membership=50, owner_inferred=80.
  /// Low-confidence aliases should be re-confirmed once before being relied on silently.
  confidence      Int      @default(50)

  /// How many times this mapping has been used without correction. Cheap signal for trust.
  hitCount        Int      @default(0)

  /// Last time this mapping was used or refreshed. Useful for stale-pruning.
  lastUsedAt      DateTime @default(now())

  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt

  // Same alias can map to different people in different teams. Unique within a team.
  @@unique([teamId, enterpriseId, alias, slackUserId])
  @@index([teamId, enterpriseId, alias])
  @@index([teamId, enterpriseId, slackUserId])
}

/// One row per Slack workspace install. Holds the bot token Bolt needs to act on behalf of that workspace.
/// Either teamId or enterpriseId is non-null (or both for Enterprise Grid orgs).
model SlackInstallation {
  id              String   @id @default(cuid())

  /// "T0123..." workspace ID. Null for org-level installs in Enterprise Grid.
  teamId          String?

  /// "E0123..." enterprise / org grid ID. Null for standard installs.
  enterpriseId    String?

  /// Slack-issued primary identifier for this install row (see InstallationStore query semantics).
  installerUserId String?

  /// Bot side
  botId           String?
  botUserId       String?
  botToken        String
  botRefreshToken String?
  botTokenExpiresAt DateTime?

  /// "app_mentions:read,chat:write,..." for diagnostics
  scopes          String?

  /// True if this is the "org-level" install row for Enterprise Grid
  isEnterpriseInstall Boolean @default(false)

  /// Full raw Installation JSON as returned by the Slack OAuth response (good for debugging/restore)
  raw             Json

  installedAt     DateTime @default(now())
  updatedAt       DateTime @updatedAt

  @@unique([teamId, enterpriseId])
  @@index([teamId])
  @@index([enterpriseId])
}
