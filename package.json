{
  "name": "aiptima",
  "version": "2.1.0",
  "description": "Aiptima — the execution hub between business owners and their team, inside Slack. Turns plain-language intent into structured, tracked work; translates between owner and team; surfaces facts (including silence) without ever judging an employee.",
  "main": "dist/index.js",
  "engines": {
    "node": ">=20.0.0"
  },
  "scripts": {
    "dev": "nodemon",
    "start": "node dist/index.js",
    "build": "tsc -p tsconfig.json",
    "typecheck": "tsc --noEmit",
    "postinstall": "prisma generate",
    "prisma:generate": "prisma generate",
    "prisma:push": "prisma db push",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:coverage": "vitest run --coverage"
  },
  "keywords": [
    "slack",
    "ai",
    "operations",
    "chief-of-staff",
    "aiptima",
    "openai",
    "prisma"
  ],
  "author": "",
  "license": "ISC",
  "devDependencies": {
    "@types/node": "^24.0.15",
    "@vitest/coverage-v8": "^3.2.4",
    "nodemon": "^3.1.10",
    "prisma": "^6.18.0",
    "ts-node": "^10.9.2",
    "typescript": "^5.8.3",
    "vitest": "^3.2.4"
  },
  "dependencies": {
    "@prisma/client": "^6.18.0",
    "@slack/bolt": "^4.4.0",
    "@slack/web-api": "^7.9.3",
    "@supabase/supabase-js": "^2.52.1",
    "dotenv": "^17.2.0",
    "express": "^5.1.0",
    "node-cron": "^4.2.1",
    "openai": "^5.10.2"
  }
}
